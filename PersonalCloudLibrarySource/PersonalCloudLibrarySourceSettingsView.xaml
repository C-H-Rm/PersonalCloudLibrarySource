<UserControl x:Class="PersonalCloudLibrarySource.PersonalCloudLibrarySourceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="620"
             d:DesignWidth="700">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <TextBlock Text="Personal Cloud Library Source"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>

            <TextBlock Text="Import a personal library from a local JSON manifest or an rclone remote manifest."
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>

            <CheckBox Content="Enable this library source"
                      IsChecked="{Binding Settings.Enabled}"
                      Margin="0,0,0,14"/>

            <TextBlock Text="Manifest Source"
                       FontSize="15"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Manifest source mode:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.ManifestSourceMode, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="520"
                     Margin="0,0,0,6"/>

            <TextBlock Text="Example: LocalFile or RcloneRemote"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Local manifest JSON path:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.LocalManifestPath, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="520"
                     Margin="0,0,0,6"/>

            <TextBlock Text="Example: D:\PersonalCloudLibrarySource\samples\personal-cloud-library.sample.json"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Rclone executable path:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.RcloneExecutablePath, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="520"
                     Margin="0,0,0,6"/>

            <TextBlock Text="Example: rclone"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Rclone remote name:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.RcloneRemoteName, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="520"
                     Margin="0,0,0,6"/>

            <TextBlock Text="Example: my_remote"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Rclone manifest path:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.RcloneManifestPath, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="520"
                     Margin="0,0,0,6"/>

            <TextBlock Text="Example: PersonalLibrary/manifest.json"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <TextBlock Text="Rclone timeout seconds:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.RcloneTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="120"
                     Margin="0,0,0,14"/>

            <TextBlock Text="Local cache folder:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBox Text="{Binding Settings.LocalCacheFolder, UpdateSourceTrigger=PropertyChanged}"
                     MinWidth="520"
                     Margin="0,0,0,6"/>

            <TextBlock Text="Example: D:\PersonalCloudLibraryCache"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <CheckBox Content="Treat missing files as uninstalled"
                      IsChecked="{Binding Settings.TreatMissingFilesAsUninstalled}"
                      Margin="0,0,0,16"/>

            <Border BorderBrush="#666666"
                    BorderThickness="1"
                    Padding="10"
                    CornerRadius="4">
                <TextBlock Text="Legal-use note: this plugin does not provide games, ROMs, BIOS files, cracks, keys, artwork, or download sources. It only imports entries from a manifest supplied by the user."
                           TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
